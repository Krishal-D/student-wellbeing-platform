<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <link rel="stylesheet" href="/stylesheets/search.css" />
  </head>
  <body>
    
    <!-- Header HTML is in a separate file -->
    <%- include("partials/header") %>

    <main class="home-main-columns">
      
      <section class="auth-section">
        <div class="home-content">
          <% if (typeof user !== 'undefined' && user) { %>
            <h1 class="home-title">Welcome back, <%= user.userType === 'admin' ? 'Admin' : user.userName %>! 🌟</h1>
            <p class="home-subtitle"><%= user.userType === 'admin' ? 'Manage your platform effectively today!' : 'Ready to take care of your wellbeing today?' %></p>
            <% if (user.userType === 'admin') { %>
              <div class="home-message">
                <p>As an administrator, you can monitor user wellbeing and manage system alerts.</p>
                <p>Use the <a href="/alertDashboard" class="home-link">Alert Dashboard</a> and <a href="/users" class="home-link">Users</a> sections to oversee the platform.</p>
              </div>
            <% } else { %>
              <div class="home-message">
                <p>Track your mood, explore your emotional journey, and discover insights about your mental wellbeing.</p>
                <p>Use the navigation above to get started with your wellbeing journey!</p>
              </div>
            <% } %>
          <% } else { %>
            <h1 class="home-title">Welcome to Wellbeing Hub 💚</h1>
            <p class="home-subtitle">Your journey to better mental health starts here</p>
            <div class="home-message">
              <p>Take control of your emotional wellbeing with our comprehensive mood tracking and mental health tools.</p>
              <div class="home-actions">
                <a href="/login" class="btn-primary">Sign In</a>
                <a href="/register" class="btn-secondary">Get Started</a>
              </div>
            </div>
          <% } %>
        </div>
      </section>

      <section class="events-section">
        <div class="recommend-section" aria-labelledby="rec-title">
        <h2 id="rec-title">Recommended for you</h2>

        <div class="rec-grid"> 
          <article class="rec-card">
            <a class="rec-thumb" href="/events/mental-health-workshop" aria-label="Mental Health Workshop">
              <img src="/images/istockphoto-1340965910-612x612.jpg" alt="Mental Health Workshop" />
            </a>
            <div class="rec-body">
              <h3 class="rec-title">
                <a href="/events/mental-health-workshop">Mental Health Workshop</a>
              </h3>
              <p class="rec-sub">Learn coping strategies</p>
              <div class="event-meta">
                <span class="event-date">17/09/2025</span>
                <span class="event-time">10:00</span>
                <span class="event-campus">Parramatta South</span>
              </div>
            </div>
          </article>

          <article class="rec-card">
            <a class="rec-thumb" href="/events/learning-skills-seminar" aria-label="Learning Skills Seminar">
              <img src="/images/Learning-Skill-icon-Graphics-26544562-1-1-580x387.jpg" alt="Learning Skills Seminar" />
            </a>
            <div class="rec-body">
              <h3 class="rec-title">
                <a href="/events/learning-skills-seminar">Learning Skills Seminar</a>
              </h3>
              <p class="rec-sub">Improve your study habits</p>
              <div class="event-meta">
                <span class="event-date">18/09/2025</span>
                <span class="event-time">11:00</span>
                <span class="event-campus">Bankstown</span>
              </div>
            </div>
          </article>

          <article class="rec-card">
            <a class="rec-thumb" href="/events/career-fair" aria-label="Career Fair">
              <img src="/images/360_F_1527954928_5UPs5ilDSieF6nu9LGfV8J36RtvDgGhF.jpg" alt="Career Fair" />
            </a>
            <div class="rec-body">
              <h3 class="rec-title">
                <a href="/events/career-fair">Career Fair</a>
              </h3>
              <p class="rec-sub">Explore job opportunities</p>
              <div class="event-meta">
                <span class="event-date">19/09/2025</span>
                <span class="event-time">09:00</span>
                <span class="event-campus">Parramatta City</span>
              </div>
            </div>
          </article>

          <article class="rec-card">
            <a class="rec-thumb" href="/events/social-mixer" aria-label="Social Mixer">
              <img src="/images/social-wellbeing-concept-icon.jpg" alt="Social Mixer" />
            </a>
            <div class="rec-body">
              <h3 class="rec-title">
                <a href="/events/social-mixer">Social Mixer</a>
              </h3>
              <p class="rec-sub">Meet new people</p>
              <div class="event-meta">
                <span class="event-date">20/09/2025</span>
                <span class="event-time">12:00</span>
                <span class="event-campus">Penrith</span>
              </div>
            </div>
          </article>
        </div> 
        </div>
      </section>
      
    </main>

    <!-- Footer HTML is in a separate file -->
    <%- include("partials/footer") %>

  </body>
</html>
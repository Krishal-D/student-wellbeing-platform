<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <link rel='stylesheet' href='/stylesheets/style.css' />
    <style>
      div.alertDivContainer {
        border: 2px solid #444444; 
        margin-top: 5px;
        margin-bottom: 20px;
        margin-left: 5px;
        margin-right: 50px;

        padding-left: 0px;
        padding-right: 40px;

        max-height: 300px;
        overflow: auto; /* For scrollbar if many elements in list */

      }

      ul.alertList {
        list-style-type: none;
      }

      li.alertElement {
        border: 1px solid #000000;
        
      }

      li.alertElement:hover {
        background-color: rgb(255, 230, 230);
      } 

      ul.alertDetails {
        list-style-type: none;
        padding-left: 5px;
      }

      
      

    </style>
  </head>
  <body>
    
    <!-- Header HTML is in a separate file -->
    <%- include("partials/header") %>

    <main>
      <h2>Alert Dashboard</h2>

      <h3>Alert List</h3>
      <p>A list of all of the Crisis Alerts that have been generated.</p>

      <!-- 
      The alerts are displayed as a nested unordered list. (<ul> with another <ul>)
      So, the <li> elements in the outer list are each individual alert, 
      and the <li> elements in the inner list are the details of that alert. (name, email etc)
       -->
      <div class="alertDivContainer">

        <ul class = "alertList">

          <li class="alertElement">
            <ul class="alertDetails">
              <li><p><b>Name:</b> (firstname surname)</p></li>
              <li><p><b>Student Email:</b> (student email)</p></li>
              <li><p><b>Date:</b> (date/time triggered)</p></li>
              <li><p><b>More Info:</b> (alert information)</p></li>
            </ul>
          </li>

          <li class="alertElement">
            <ul class="alertDetails">
              <li><p><b>Name:</b> (firstname surname)</p></li>
              <li><p><b>Student Email:</b> (student email)</p></li>
              <li><p><b>Date:</b> (date/time triggered)</p></li>
              <li><p><b>More Info:</b> (alert information)</p></li>
            </ul>
          </li>

          <li class="alertElement">
            <ul class="alertDetails">
              <li><p><b>Name:</b> (firstname surname)</p></li>
              <li><p><b>Student Email:</b> (student email)</p></li>
              <li><p><b>Date:</b> (date/time triggered)</p></li>
              <li><p><b>More Info:</b> (alert information)</p></li>
            </ul>
          </li>

          <li class="alertElement">
            <ul class="alertDetails">
              <li><p><b>Name:</b> (firstname surname)</p></li>
              <li><p><b>Student Email:</b> (student email)</p></li>
              <li><p><b>Date:</b> (date/time triggered)</p></li>
              <li><p><b>More Info:</b> (alert information)</p></li>
            </ul>
          </li>

          <li class="alertElement">
            <ul class="alertDetails">
              <li><p><b>Name:</b> (firstname surname)</p></li>
              <li><p><b>Student Email:</b> (student email)</p></li>
              <li><p><b>Date:</b> (date/time triggered)</p></li>
              <li><p><b>More Info:</b> (alert information)</p></li>
            </ul>
          </li>
          
        </ul>

      </div>

    </main>

    <!-- Footer HTML is in a separate file -->
    <%- include("partials/footer") %>

  </body>
</html>
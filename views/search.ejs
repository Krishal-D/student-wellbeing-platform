<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/search.css" />
  </head>
  <body>
    
    <!-- Header HTML is in a separate file -->
    <%- include("partials/header") %>

    <main class="container">
      <h2>Searching</h2>
    <form action="/search" method="GET">
        <div class="search-bar">
          <input type="text" name="query" placeholder="Search..." />
          <button type="submit">Search</button>
        </div>
      <br /><br />
      
      <div class="dropdowns-row">
      <div class="dropdowns">
        <select id="category" name="category">
          <option value="">Category</option>
          <option value="fitness">Fitness</option>
          <option value="counselling">Counselling</option>
          <option value="socialnetwork">Social Network</option>
        </select>
      </div>

      <div class="dropdowns">
        <select id="date" name="date">
          <option value="">Date</option>
          <option value="17-09-2025">17, September 2025</option>
          <option value="18-09-2025">18, September 2025</option>
          <option value="19-09-2025">19, September 2025</option>
        </select>
      </div>

      <div class="dropdowns">
        <select id="time" name="time">
          <option value="">Time</option>
          <option value="09:00">09:00</option>
          <option value="10:00">10:00</option>
          <option value="11:00">11:00</option>
          <option value="12:00">12:00</option>
        </select>
      </div>

      <div class="dropdowns">
        <select id="campus" name="campus">
          <option value="">Campus</option>
          <option value="bankstown">Bankstown</option>
          <option value="campbelltown">Campbelltown</option>
          <option value="hawkesbury">Hawkesbury</option>
          <option value="parramattacity">Parramatta City</option>
          <option value="parramattasouth">Parramatta South</option>
          <option value="penrith">Penrith</option>
          <option value="online">Online</option>
        </select>
      </div>
      </div>
    </form>
     
    <!-- Search Results Section -->
    <% if (typeof results !== 'undefined' && results.hasResults) { %>
      <section class="search-results">
        <h3>Search Results</h3>
        
        <!-- Event Results -->
        <% if (results.events && results.events.length > 0) { %>
          <div class="results-section">
            <h4>Events (<%= results.events.length %>)</h4>
            <div class="rec-grid">
              <% results.events.forEach(function(event) { %>
                <article class="rec-card">
                  <a class="rec-thumb" href="/events/<%= event.id %>" aria-label="<%= event.title %>">
                    <img src="<%= event.image %>" alt="<%= event.title %>" />
                  </a>
                  <div class="rec-body">
                    <h3 class="rec-title">
                      <a href="/events/<%= event.id %>"><%= event.title %></a>
                    </h3>
                    <p class="rec-sub"><%= event.subtitle %></p>
                    <div class="event-meta">
                      <span class="event-date"><%= new Date(event.date).toLocaleDateString('en-AU') %></span>
                      <span class="event-time"><%= event.time %></span>
                      <span class="event-campus"><%= event.campus.charAt(0).toUpperCase() + event.campus.slice(1).replace(/([A-Z])/g, ' $1') %></span>
                    </div>
                  </div>
                </article>
              <% }); %>
            </div>
          </div>
        <% } %>
        
        <!-- Item Results -->
        <% if (results.items && results.items.length > 0) { %>
          <div class="results-section">
            <h4>Resources (<%= results.items.length %>)</h4>
            <div class="items-list">
              <% results.items.forEach(function(item) { %>
                <div class="item-card">
                  <h4><%= item.title %></h4>
                  <p><%= item.summary %></p>
                  <div class="item-meta">
                    <span class="item-category"><%= item.category %></span>
                    <span class="item-type"><%= item.type %></span>
                    <% if (item.date) { %>
                      <span class="item-date"><%= item.date %></span>
                    <% } %>
                    <span class="item-location"><%= item.location %></span>
                  </div>
                  <% if (item.bookUrl) { %>
                    <a href="<%= item.bookUrl %>" class="btn btn-primary">Book</a>
                  <% } %>
                </div>
              <% }); %>
            </div>
          </div>
        <% } %>
      </section>
    <% } else if (typeof results !== 'undefined' && !results.hasResults && (query || category || date || time || campus || type)) { %>
      <section class="search-results">
        <h3>No Results Found</h3>
        <p>Try adjusting your search criteria or browse our <a href="/">recommended events</a>.</p>
      </section>
    <% } %>
    
    </main>
    
    <!-- Footer HTML is in a separate file -->
    <%- include("partials/footer") %>

  </body>
</html>
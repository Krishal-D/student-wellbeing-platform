<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
  </head>
  <body>
    
    <!-- Header HTML is in a separate file -->
    <%- include("partials/header") %>

    <main class="container">
      <h2>Searching</h2>
      <form action="/search" method="GET">
        <input type="text" name="query" placeholder="Search..." />
        <button type="submit">Search</button>
      <br /><br />
      
      <form class="dropdown" id="category" action="/search" method="GET">
        <select id="category" name="category">
          <option value="">Category</option>
          <option value="fitness">Fitness</option>
          <option value="counselling">Counselling</option>
          <option value="socialnetwork">Social Network</option>
        </select>

      <form class="dropdown" id="date" action="/search" method="GET">
        <select id="date" name="date">
          <option value="">Date</option>
          <option value="17-09-2025">17, September 2025</option>
          <option value="18-09-2025">18, September 2025</option>
          <option value="19-09-2025">19, September 2025</option>
        </select>
      
      <form class="dropdown" id="campus" action="/search" method="GET">
        <select id="campus" name="campus">
          <option value="">Campus</option>
          <option value="bankstown">Bankstown</option>
          <option value="campbelltown">Campbelltown</option>
          <option value="hawkesbury">Hawkesbury</option>
          <option value="parramattacity">Parramatta City</option>
          <option value="parramattasouth">Parramatta South</option>
          <option value="penrith">Penrith</option>
        </select>
      
      <form class="dropdown" id="time" action="/search" method="GET">
        <select id="time" name="time">
          <option value="">Time</option>
          <option value="09:00">09:00</option>
          <option value="10:00">10:00</option>
          <option value="11:00">11:00</option>
          <option value="12:00">12:00</option>
        </select>
      </form>
      <br /><br />
      <!-- Recommended for you -->
    <section class="recommend-section" aria-labelledby="rec-title">
      <h2 id="rec-title">Recommended for you</h2>

      <div class="rec-grid">
        <!-- Card 1 -->
        <article class="rec-card">
          <a class="rec-thumb" href="/events/mental-health-workshop" aria-label="Mental Health Workshop">
            <img src="/images/istockphoto-1340965910-612x612.jpg" alt="Mental Health Workshop" />
          </a>
          <div class="rec-body">
            <h3 class="rec-title">
              <a href="/events/mental-health-workshop">Mental Health Workshop</a>
            </h3>
            <p class="rec-sub">Learn coping strategies</p>
          </div>
        </article>

        <!-- Card 2 -->
        <article class="rec-card">
          <a class="rec-thumb" href="/events/Learning-skills-seminar" aria-label="Learning Skills Seminar">
            <img src="/images/Learning-Skill-icon-Graphics-26544562-1-1-580x387.jpg" alt="Learning Skills Seminar" />
          </a>
          <div class="rec-body">
            <h3 class="rec-title">
              <a href="/events/Learning-skills-seminar">Learning Skills Seminar</a>
            </h3>
            <p class="rec-sub">Improve your study habits</p>
          </div>
        </article>

        <!-- Card 3 -->
        <article class="rec-card">
          <a class="rec-thumb" href="/events/career-fair" aria-label="Career Fair"></a>
          <div class="rec-body">
            <h3 class="rec-title">
              <a href="/events/career-fair">Career Fair</a>
            </h3>
            <p class="rec-sub">Explore job opportunities</p>
          </div>
        </article>

        <!-- Card 4 -->
        <article class="rec-card">
          <a class="rec-thumb" href="/events/social-mixer" aria-label="Social Mixer"></a>
          <div class="rec-body">
            <h3 class="rec-title">
              <a href="/events/social-mixer">Social Mixer</a>
            </h3>
            <p class="rec-sub">Meet new people</p>
          </div>
        </article>
      </div>
    </section>
    </main>
    
    <!-- Footer HTML is in a separate file -->
    <%- include("partials/footer") %>

  </body>
</html>
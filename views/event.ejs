<!DOCTYPE html>
<html>
  <head>
    <title><%= title %></title>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <link rel="stylesheet" href="/stylesheets/style.css" />
    <link rel="stylesheet" href="/stylesheets/search.css" />
    
    <%- include("partials/header") %>

    <main class="event-container">
      <a href="/" class="back-link">← Back to Home</a>
      
      <div class="event-header">
        <img src="<%= event.image %>" alt="<%= event.title %>" class="event-image" /> 
        <!--<h1 class="event-title"><%= event.title %></h1>-->
        <p class="event-subtitle"><%= event.subtitle %></p>
      </div>

      <div class="event-details">
        <div class="detail-card">
          <div class="detail-label">Date</div>
          <div class="detail-value"><%= new Date(event.date).toLocaleDateString('en-AU', { 
            weekday: 'long', 
            year: 'numeric', 
            month: 'long', 
            day: 'numeric' 
          }) %></div>
        </div>
        
        <div class="detail-card">
          <div class="detail-label">Time</div>
          <div class="detail-value"><%= event.time %></div>
        </div>
        
        <div class="detail-card">
          <div class="detail-label">Duration</div>
          <div class="detail-value"><%= event.duration %></div>
        </div>
        
        <div class="detail-card">
          <div class="detail-label">Campus</div>
          <div class="detail-value"><%= event.campus.charAt(0).toUpperCase() + event.campus.slice(1).replace(/([A-Z])/g, ' $1') %></div>
        </div>
        
        <div class="detail-card">
          <div class="detail-label">Instructor</div>
          <div class="detail-value"><%= event.instructor %></div>
        </div>
        
        <div class="detail-card">
          <div class="detail-label">Max Participants</div>
          <div class="detail-value"><%= event.maxParticipants %></div>
        </div>
      </div>

      <div class="event-description">
        <h3>About This Event</h3>
        <p><%= event.description %></p>
      </div>

      <div class="event-features">
        <h3>What You'll Get</h3>
        <ul class="features-list">
          <% event.details.forEach(function(detail) { %>
            <li><%= detail %></li>
          <% }); %>
        </ul>
      </div>

      <div class="action-buttons">
        <a href="<%= event.bookUrl %>" class="btn btn-primary">Book This Event</a>
        <a href="/search" class="btn btn-secondary">Search More Events</a>
      </div>
    </main>

    <%- include("partials/footer") %>

  </body>
</html>
